# =============================================================================
# Arthasee — single root .gitignore, covering both backend/ and frontend/.
# Previously two separate files (root + frontend/.gitignore); merged since
# a monorepo with per-directory .gitignores just invites "which one actually
# applies here" confusion. Frontend-only patterns below are explicitly
# scoped under frontend/ (rather than left bare) so they can't accidentally
# start matching something unrelated under backend/.
# =============================================================================

# ── Backend (Django) ─────────────────────────
backend/venv/
backend/.venv/
backend/.env
backend/staticfiles/
backend/media/
backend/db.sqlite3

# ── Frontend (Next.js) ───────────────────────
frontend/node_modules/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

frontend/coverage/
frontend/.next/
# frontend/out/ — the static export build output. deploy.yml rsyncs this
# directory to the droplet on every deploy (see "Upload static export
# build" step) — it's generated fresh on every build, never hand-edited,
# and must stay gitignored the same way backend/staticfiles/ does.
frontend/out/
frontend/build/

frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts

frontend/Dockerfile.dev

# ── Docker — local dev override, never commit ─
# See docker-compose.override.yml's own header comment for why.
docker-compose.override.yml

# ── Python (anywhere in project) ─────────────
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# ── Env files (anywhere in project) ──────────
.env
.env.local
.env.*
!.env.example

# ── General / OS ──────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
*.log
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Editor ───────────────────────────────────
.vscode/
.idea/
*.swp
*.swo